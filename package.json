{
  "name": "whiteroom-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "test:game": "npm --prefix apps/game test",
    "lint:game": "npm --prefix apps/game run lint",
    "build:game": "npm --prefix apps/game run build",
    "check:game": "npm run test:game && npm run lint:game && npm run build:game"
  },
  "dependencies": {
    "acorn": "^8.15.0",
    "jose": "^6.1.0",
    "three": "0.185.1",
    "ws": "^8.21.0",
    "yauzl": "^3.2.0"
  }
}
