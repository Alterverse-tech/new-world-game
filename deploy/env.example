# 《眠海》平台生产环境变量样例 —— 复制为 .env（docker compose）
# 或 /etc/whiteroom/env（systemd）后填入真实值；不要提交到仓库。

# 必填：创作者上传令牌与管理员令牌（各 ≥16 字节，且互不相同）
WHITEROOM_PORTAL_TOKEN=change-me-creator-secret-at-least-16-bytes
WHITEROOM_ADMIN_TOKEN=change-me-admin-secret-at-least-16-bytes

# 强烈建议：独立密钥（各 ≥32 字节），避免与管理员令牌耦合
#WHITEROOM_LOBBY_OWNER_SECRET=
#WHITEROOM_ACCOUNT_SESSION_SECRET=
#WHITEROOM_DREAMSEA_SECRET=

# 可选：潜流（AI 造物）worker 桥接令牌（≥32 字节，配置后启用愿念功能）
#WHITEROOM_PROP_WORKER_TOKEN=

# 可选：Supabase 账号体系（两者需同时配置）
#WHITEROOM_SUPABASE_URL=
#WHITEROOM_SUPABASE_PUBLISHABLE_KEY=

# 可选：跨域来源（默认 *；生产建议收敛为游戏客户端域名）
#WHITEROOM_CORS_ORIGIN=https://game.example.com

# 可选：浮力法则参数
#WHITEROOM_DREAMSEA_SINK_AFTER_MS=2592000000
#WHITEROOM_DREAMSEA_SINK_PATROL_MS=600000
